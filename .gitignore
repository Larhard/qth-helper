# ── Flutter / Dart ────────────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
/coverage/
**/doc/api/

# Symbolication & obfuscation maps (generated during release builds)
app.*.symbols
app.*.map.json

# ── Android ───────────────────────────────────────────────────────────────────
android/.gradle/
android/local.properties          # machine-specific SDK/NDK paths
android/key.properties            # signing credentials — NEVER commit
android/app/google-services.json  # Firebase — add only if used
/android/app/debug
/android/app/profile
/android/app/release

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/          # VS Code launch configs are usually machine-specific

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
*.swp
*.swo
*.log

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python

# ── Generated data assets ────────────────────────────────────────────────────
# These files are REQUIRED by Flutter at build time but are NOT committed.
# They are gitignored so `git add .` can never accidentally stage them.
#
# Before your first build, run once (no internet needed, instant):
#   python scripts/create_stubs.py
#
# For full city/port data run the fetch scripts afterwards:
#   python scripts/fetch_cities.py
#   python scripts/fetch_ports.py --wpi-file ...
#
# assets/cities.tsv is the only data file committed (260 KB, always present).
assets/cities_precise.tsv
assets/cities_detailed.tsv
assets/ports.tsv
#
# assets/icon/app_icon.png     ← committed (generated by scripts/generate_icon.py)
# assets/icon/app_icon_fg.png  ← committed

# ── Raw upstream data (NOT in repo — download from source) ───────────────────
# data/UpdatedPub150.csv  ← NGA WPI raw CSV; download from NGA or pass as
#                            --wpi-file to scripts/fetch_ports.py
data/

# ── Python script cache ───────────────────────────────────────────────────────

# ── Misc ──────────────────────────────────────────────────────────────────────
*.class
migrate_working_dir/
.atom/
.buildlog/
.history
.svn/
.swiftpm/
**/ios/Flutter/.last_build_id

# fetch_ports.py persistent data cache (GeoNames + OSM, accumulates across runs)
scripts/.ports_cache.json

# ── Security ──────────────────────────────────────────────────────────────────
android/key.properties       # release signing credentials — NEVER commit
*.jks                        # Java keystores
*.keystore
