# ── Flutter / Dart ────────────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
/coverage/
**/doc/api/

# Symbolication & obfuscation maps (generated during release builds)
app.*.symbols
app.*.map.json

# ── Android ───────────────────────────────────────────────────────────────────
android/.gradle/
android/local.properties          # machine-specific SDK/NDK paths
android/key.properties            # signing credentials — NEVER commit
android/app/google-services.json  # Firebase — add only if used
/android/app/debug
/android/app/profile
/android/app/release

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/          # VS Code launch configs are usually machine-specific

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
*.swp
*.swo
*.log

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python

# ── Generated assets — keep in repo so CI/CD can build offline ───────────────
# assets/cities.tsv        ← committed (one-time download, needed for build)
# assets/icon/app_icon.png ← committed (generated by scripts/generate_icon.py)
# assets/icon/app_icon_fg.png ← committed

# ── Misc ──────────────────────────────────────────────────────────────────────
*.class
migrate_working_dir/
.atom/
.buildlog/
.history
.svn/
.swiftpm/
**/ios/Flutter/.last_build_id

# fetch_ports.py GeoNames cache (intermediate run state)
scripts/.geonames_cache.json
